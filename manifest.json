{
  "manifest_version": 3,
  "name": "Page Image Saver",
  "version": "1.0.0",
  "description": "現在開いているページ内の画像URLを収集して保存します。",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "画像保存"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
